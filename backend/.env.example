# MySQL 管理员连接，仅用于初始化数据库、创建业务用户和授权
MYSQL_ADMIN_HOST=127.0.0.1
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=请在本地 .env 中填写

# 业务数据库；后端运行时只使用这个账号
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rk_network_engineer
DB_USER=rk_bank
DB_PASSWORD=请在本地 .env 中填写强密码

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=请在本地 .env 中填写随机长字符串
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
COOKIE_SECURE=false

# DeepSeek v4，可选；不配置时系统仍可运行，但 AI 辅助接口会返回配置提示
AI_ENABLED=true
DEEPSEEK_API_KEY=请在本地 .env 中填写
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# 合规搜索候选发现，可选
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=
BING_SEARCH_API_KEY=请在本地 .env 中填写
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# OCR，可选；在线 OCR 只在显式运行 OCR 脚本时使用
OCR_SPACE_API_KEY=请在本地 .env 中填写
