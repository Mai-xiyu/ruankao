# MySQL 管理员连接，仅用于初始化数据库、创建业务用户、授权
MYSQL_ADMIN_HOST=127.0.0.1
MYSQL_ADMIN_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=请在本地 .env 中填写

# 业务数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rk_network_engineer
DB_USER=rk_bank
DB_PASSWORD=请在本地 .env 中填写一个强密码
# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# DeepSeek v4，可选；不配置时系统仍可运行，但 AI 辅助接口会返回配置提示
AI_ENABLED=true
DEEPSEEK_API_KEY=请在本地 .env 中填写
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# 全网搜索候选发现，可选；推荐自建 SearXNG，也可使用 Bing Search API
SEARCH_PROVIDER=searxng
SEARXNG_BASE_URL=
BING_SEARCH_API_KEY=请在本地 .env 中填写
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
